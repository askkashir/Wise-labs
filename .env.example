# WISE Lab — environment variables
# Copy this file to .env (gitignored) and fill in real values.
# NEVER commit real secrets — this is a public repository.

# --- Supabase ---
# From your Supabase project settings > API. Required for application
# submissions, the blog, and the admin portal to talk to a live backend.
# Without these set, forms fall back to a local-only queued submission
# (see src/lib/forms/submitApplication.ts) so the UI still works for
# development without a backend.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Floating WhatsApp button ---
# Full international number, no spaces/symbols except the leading +.
# Example: +923001234567
# Leave empty to hide the floating WhatsApp button entirely.
VITE_WHATSAPP_NUMBER=

# --- Feature flags ---
# Live stats + countdown section (Phase 9). Off by default — there is no
# real data source wired up yet. Set to "true" once real stats are ready.
VITE_FEATURE_LIVE_STATS=false

# --- Supabase Edge Function secrets (set via `supabase secrets set`, NOT here) ---
# RESEND_API_KEY        — for the submission-notification edge function
# NOTIFY_EMAIL_TO        — address that receives new-submission notifications
